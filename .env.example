# Django
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgresql://broker:broker@db:5432/broker_db
DJANGO_SETTINGS_MODULE=config.settings.local

# Redis
REDIS_URL=redis://redis:6379/0

# AI Providers (configure at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Market Data — Alpaca (required for live prices)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Market Data — Alpha Vantage (optional, for news & sentiment)
ALPHA_VANTAGE_API_KEY=

# Telegram (optional but recommended)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Broker mode: "paper" (default) or "alpaca" (real trading - future)
BROKER_BACKEND=paper

# AI analysis schedule in minutes
AI_ANALYSIS_INTERVAL=30

# CORS for React dev server
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Postgres (used by docker-compose)
POSTGRES_DB=broker_db
POSTGRES_USER=broker
POSTGRES_PASSWORD=broker
